# ───────────────────────────────────────────────────────────────
# Template for local .env.local — copy this file to `.env.local`
# and fill in your real values. Never commit .env.local.
# Vite automatically loads it in dev & build.
# ───────────────────────────────────────────────────────────────

# ════════ FRONTEND (safe to ship in the bundle) ════════
# These are prefixed with VITE_ so Vite inlines them into the built JS.
# Anything here is PUBLIC — assume the whole world will see it.

# Bot's @username (without the @). What comes after t.me/
# Example: if your bot is https://t.me/digits_game_bot → digits_game_bot
VITE_BOT_USERNAME=your_bot_username

# Mini App short name you set in @BotFather with /newapp
# Example: "play" → final URL https://t.me/your_bot/play
VITE_APP_NAME=play


# ════════ SERVER-ONLY (NEVER prefix with VITE_) ════════
# These are read by your backend / build scripts only. Do NOT expose to frontend:
# - anyone can extract VITE_ values from the JS bundle and abuse them
# - with the bot token they can send messages as your bot, delete data, etc.

# Bot API token from @BotFather. Used by the backend to:
#   1) validate the HMAC signature of Telegram initData on every request
#   2) call the Telegram Bot API (send messages, answer queries)
# Format: 1234567890:AAH...
BOT_TOKEN=

# Shared secret pinned to the Telegram webhook. Set when calling setWebhook
# with the `secret_token` field, then echoed back by Telegram in the
# `X-Telegram-Bot-Api-Secret-Token` header on every update. Without this,
# anyone could POST forged updates to /api/tg-webhook.
# Pick any opaque random string (256 bits is plenty), e.g.
#   openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Separate token for the admin debug endpoints (/api/debug/...). Required so
# the bot token never lands in URL access logs. Generate a fresh value:
#   openssl rand -hex 32
ADMIN_TOKEN=

# Persistent path for the JSON store. The default `./data/db.json` lives
# inside the container — mount a Railway volume and point this at it
# (e.g. /data/db.json) or every redeploy wipes user state.
DB_PATH=

# Public URL of the deployed mini-app (used for the "Грати" web_app button
# in push notifications). Defaults to digits-tma-production.up.railway.app.
APP_URL=
