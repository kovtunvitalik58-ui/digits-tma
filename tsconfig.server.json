{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Node",
    "outDir": "./dist-server",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "server/**/*",
    "src/game/types.ts",
    "src/game/ops.ts",
    "src/game/engine.ts",
    "src/game/solver.ts",
    "src/game/generator.ts",
    "src/lib/kyivDate.ts"
  ]
}
